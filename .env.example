# =============================================================================
# Supabase — create a project at https://supabase.com
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose client-side; used only in server API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# LLM Provider — OpenAI-compatible
# To use Stanford AI Playground: change OPENAI_BASE_URL to the playground endpoint
# and set the appropriate API key below.
# =============================================================================
# Stanford AI Playground (current)
OPENAI_API_KEY=sk-your-stanford-key-here
OPENAI_BASE_URL=https://aiapi-prod.stanford.edu/v1
OPENAI_MODEL=gpt-4.1
# Available models: gpt-4.1, gpt-4.omini, gpt-5, gpt-5-mini
# To use OpenAI directly instead: set OPENAI_BASE_URL=https://api.openai.com/v1 and use your OpenAI key

# =============================================================================
# TTS (Text-to-Speech) — OpenAI TTS API
#
# Separate from the Stanford AI Playground key above.
# Stanford's gateway only supports chat completions — TTS requires a direct
# OpenAI key (or any OpenAI-compatible TTS provider).
#
# Cost: ~$0.015/1k characters with tts-1 (~$0.03-0.10 per full interview)
# Get a key at: https://platform.openai.com/api-keys
#
# If OPENAI_TTS_API_KEY is not set, the app automatically falls back to the
# browser's built-in SpeechSynthesis (lower quality but functional).
# =============================================================================
OPENAI_TTS_API_KEY=sk-your-openai-key-here
OPENAI_TTS_BASE_URL=https://api.openai.com/v1
OPENAI_TTS_VOICE=nova
# Voice options: alloy · echo · fable · onyx · nova (warm female) · shimmer (lighter female)
OPENAI_TTS_MODEL=tts-1
# Model options: tts-1 (fast, ~300ms latency) | tts-1-hd (higher quality, ~600ms latency)


# Uncomment and fill in when Transcribe integration is implemented.
# See lib/transcribe/index.ts for the integration stub.
# =============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_TRANSCRIBE_BUCKET=sparkme-audio

# =============================================================================
# App config
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
