# =============================================================================
# Supabase — create a project at https://supabase.com
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose client-side; used only in server API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# LLM Provider — OpenAI-compatible
# To use Stanford AI Playground: change OPENAI_BASE_URL to the playground endpoint
# and set the appropriate API key below.
# =============================================================================
# Stanford AI Playground (current)
OPENAI_API_KEY=sk-your-stanford-key-here
OPENAI_BASE_URL=https://aiapi-prod.stanford.edu/v1
OPENAI_MODEL=gpt-4.1
# Available models: gpt-4.1, gpt-4.omini, gpt-5, gpt-5-mini
# To use OpenAI directly instead: set OPENAI_BASE_URL=https://api.openai.com/v1 and use your OpenAI key

# =============================================================================
# AWS Transcribe — NOT active in MVP; architecture placeholder
# Uncomment and fill in when Transcribe integration is implemented.
# See lib/transcribe/index.ts for the integration stub.
# =============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_TRANSCRIBE_BUCKET=sparkme-audio

# =============================================================================
# App config
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
